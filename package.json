{
  "name": "soulmatch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && pnpm install && pnpm build && cd ../server && pnpm install && pnpm build",
    "start": "node server/dist/index.js",
    "dev:client": "cd client && pnpm dev",
    "dev:server": "cd server && pnpm dev"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sweph",
      "esbuild"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
