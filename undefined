import { Router, Request, Response } from "express";
import { getDb } from "../lib/db.js";
import { sql } from "drizzle-orm";

export const patrolApiRouter = Router();

// Diagnostic: list all tables with patrol/finding/scout in name
patrolApiRouter.get("/schema-check", async (_req: Request, res: Response) => {
  try {
    const db = getDb();
    const result = await db.execute(sql`SELECT tablename FROM pg_tables WHERE schemaname = 'public' AND (tablename ILIKE '%patrol%' OR tablename ILIKE '%finding%' OR tablename ILIKE '%scout%' OR tablename ILIKE '%deep%')`);
    res.json({ tables: result.rows });
  } catch (err) {
    res.status(500).json({ error: String(err) });
  }
});

// Diagnostic: get sample data from any table  
patrolApiRouter.get("/table-sample", async (req: Request, res: Response) => {
  try {
    const table = String(req.query.table || "");
    if (!table || !/^[a-z_]+$/.test(table)) { res.status(400).json({ error: "invalid table name" }); return; }
    const db = getDb();
    const result = await db.execute(sql.raw(`SELECT * FROM ${table} ORDER BY created_at DESC LIMIT 3`));
    res.json({ table, rows: result.rows, count: result.rows?.length });
  } catch (err) {
    res.status(500).json({ error: String(err) });
  }
});
