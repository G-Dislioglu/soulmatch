/**
 * Minimal file reader endpoint — reads repo files via GitHub API
 * Side-effect: registers on opusBridgeRouter via lazy dynamic import
 */
setTimeout(async () => {
  try {
    const { opusBridgeRouter } = await import('./opusBridge.js');
    const { Request, Response } = await import('express');

    opusBridgeRouter.get('/read-file', async (req: any, res: any) => {
      try {
        const filePath = String(req.query.path || '');
        if (!filePath) { res.status(400).json({ error: 'path query param required' }); return; }
        const token = process.env.GITHUB_TOKEN || process.env.GH_PAT || process.env.RENDER_GIT_TOKEN || '';
        const url = `https://api.github.com/repos/G-Dislioglu/soulmatch/contents/${filePath}?ref=main`;
        const headers: Record<string,string> = { Accept: 'application/vnd.github.v3.raw' };
        if (token) headers['Authorization'] = `Bearer ${token}`;
        const resp = await fetch(url, { headers });
        if (!resp.ok) { res.status(resp.status).json({ error: `GitHub ${resp.status}: ${resp.statusText}` }); return; }
        const content = await resp.text();
        res.json({ path: filePath, size: content.length, content });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });
    console.log('[file-reader] /read-file endpoint registered');
  } catch (err) {
    console.error('[file-reader] Failed:', err);
  }
}, 200);
