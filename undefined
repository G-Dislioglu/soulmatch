/**
 * Patrol Routes — side-effect mount onto opusBridgeRouter
 * Import this file anywhere to register patrol endpoints on the opus-bridge router.
 */
import { opusBridgeRouter } from './opusBridge.js';
import { Request, Response } from 'express';
import { getDb } from '../lib/db.js';
import { sql } from 'drizzle-orm';

// Helper: try multiple table name candidates
async function queryTable(db: any, candidates: string[], extra = '', limit = 50): Promise<any[]> {
  for (const table of candidates) {
    try {
      const q = `SELECT * FROM "${table}" ${extra} LIMIT ${limit}`;
      const result = await db.execute(sql.raw(q));
      return result.rows || [];
    } catch { continue; }
  }
  return [];
}

// GET /patrol-status
opusBridgeRouter.get('/patrol-status', async (_req: Request, res: Response) => {
  try {
    const db = getDb();
    // Discover tables
    const tablesResult = await db.execute(
      sql`SELECT tablename FROM pg_tables WHERE schemaname = 'public' AND (tablename LIKE '%patrol%' OR tablename LIKE '%finding%' OR tablename LIKE '%scout%')`
    );
    const tableNames = (tablesResult.rows || []).map((r: any) => r.tablename);

    const findings = await queryTable(db,
      ['scout_patrol_findings', 'builder_patrol_findings', 'patrol_findings'],
      'ORDER BY created_at DESC', 200);
    const rounds = await queryTable(db,
      ['scout_patrol_rounds', 'builder_patrol_rounds', 'patrol_rounds'],
      'ORDER BY created_at DESC', 50);
    const deepModels = await queryTable(db,
      ['scout_deep_models', 'builder_deep_models', 'deep_patrol_models', 'patrol_deep_models'],
      '', 50);

    const bySeverity: Record<string, number> = {};
    const byStatus: Record<string, number> = {};
    for (const f of findings) {
      const sev = (f as any).severity || 'unknown';
      const st = (f as any).status || 'unknown';
      bySeverity[sev] = (bySeverity[sev] || 0) + 1;
      byStatus[st] = (byStatus[st] || 0) + 1;
    }

    res.json({
      tables: tableNames,
      totalFindings: findings.length,
      bySeverity,
      byStatus,
      totalRounds: rounds.length,
      lastRound: rounds[0] ? (rounds[0] as any).created_at : null,
      deepModels: deepModels.length,
      recentFindings: findings.slice(0, 5),
    });
  } catch (err) {
    res.status(500).json({ error: String(err) });
  }
});

// GET /patrol-findings
opusBridgeRouter.get('/patrol-findings', async (req: Request, res: Response) => {
  try {
    const db = getDb();
    const limit = Math.min(Number(req.query.limit) || 50, 200);
    const severity = req.query.severity ? String(req.query.severity) : null;
    const where = severity ? `WHERE severity = '${severity.replace(/'/g, "''")}'` : '';
    const findings = await queryTable(db,
      ['scout_patrol_findings', 'builder_patrol_findings', 'patrol_findings'],
      `${where} ORDER BY created_at DESC`, limit);
    res.json({ findings, count: findings.length });
  } catch (err) {
    res.status(500).json({ error: String(err) });
  }
});

