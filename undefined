// GET /read-file — utility: read any repo file (for pipeline debugging)
opusBridgeRouter.get('/read-file', async (req: Request, res: Response) => {
  try {
    const filePath = String(req.query.path || '');
    if (!filePath) { res.status(400).json({ error: 'path query param required' }); return; }
    const token = process.env.GITHUB_TOKEN || process.env.GH_PAT || '';
    const url = `https://api.github.com/repos/G-Dislioglu/soulmatch/contents/${filePath}?ref=main`;
    const resp = await fetch(url, { headers: { Authorization: `Bearer ${token}`, Accept: 'application/vnd.github.v3.raw' } });
    if (!resp.ok) { res.status(resp.status).json({ error: `GitHub: ${resp.statusText}` }); return; }
    const content = await resp.text();
    res.json({ path: filePath, size: content.length, content });
  } catch (err) {
    res.status(500).json({ error: String(err) });
  }
});

