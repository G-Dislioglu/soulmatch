/**
 * Bootstrap for builder internals.
 * Side-effect import this from any small lib file.
 * Uses dynamic import() to avoid circular dependency with opusBridge.
 */
setTimeout(async () => {
  try {
    const { opusBridgeRouter } = await import('../routes/opusBridge.js');
    const { registerInternalRoutes } = await import('./builderInternals.js');
    registerInternalRoutes(opusBridgeRouter);
  } catch (err) {
    console.error('[internals-bootstrap] Failed:', err);
  }
}, 200);
