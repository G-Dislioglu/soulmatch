/**
 * Patrol Routes — lazy mount onto opusBridgeRouter
 * Uses dynamic import() to avoid circular dependency.
 * Side-effect import this file from any already-loaded module.
 */
import { Request, Response, Router } from 'express';
import { getDb } from '../lib/db.js';
import { sql } from 'drizzle-orm';

async function queryTable(db: any, candidates: string[], extra = '', limit = 50): Promise<any[]> {
  for (const table of candidates) {
    try {
      const result = await db.execute(sql.raw(`SELECT * FROM "${table}" ${extra} LIMIT ${limit}`));
      return result.rows || [];
    } catch { continue; }
  }
  return [];
}

// Lazy-mount: dynamic import avoids circular opusBridge -> vordenker -> patrolMount -> opusBridge
setTimeout(async () => {
  try {
    const { opusBridgeRouter } = await import('./opusBridge.js');

    opusBridgeRouter.get('/patrol-status', async (_req: Request, res: Response) => {
      try {
        const db = getDb();
        const tablesResult = await db.execute(
          sql`SELECT tablename FROM pg_tables WHERE schemaname = 'public' AND (tablename LIKE '%patrol%' OR tablename LIKE '%finding%' OR tablename LIKE '%scout%')`
        );
        const tableNames = (tablesResult.rows || []).map((r: any) => r.tablename);
        const findings = await queryTable(db, ['scout_patrol_findings', 'builder_patrol_findings', 'patrol_findings'], 'ORDER BY created_at DESC', 200);
        const rounds = await queryTable(db, ['scout_patrol_rounds', 'builder_patrol_rounds', 'patrol_rounds'], 'ORDER BY created_at DESC', 50);
        const deepModels = await queryTable(db, ['scout_deep_models', 'builder_deep_models', 'deep_patrol_models'], '', 50);
        const bySeverity: Record<string, number> = {};
        const byStatus: Record<string, number> = {};
        for (const f of findings) {
          bySeverity[(f as any).severity || 'unknown'] = (bySeverity[(f as any).severity || 'unknown'] || 0) + 1;
          byStatus[(f as any).status || 'unknown'] = (byStatus[(f as any).status || 'unknown'] || 0) + 1;
        }
        res.json({ tables: tableNames, totalFindings: findings.length, bySeverity, byStatus, totalRounds: rounds.length, lastRound: rounds[0] ? (rounds[0] as any).created_at : null, deepModels: deepModels.length, recentFindings: findings.slice(0, 5) });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });

    opusBridgeRouter.get('/patrol-findings', async (req: Request, res: Response) => {
      try {
        const db = getDb();
        const limit = Math.min(Number(req.query.limit) || 50, 200);
        const severity = req.query.severity ? String(req.query.severity) : null;
        const where = severity ? `WHERE severity = '${severity.replace(/'/g, "''")}'` : '';
        const findings = await queryTable(db, ['scout_patrol_findings', 'builder_patrol_findings', 'patrol_findings'], `${where} ORDER BY created_at DESC`, limit);
        res.json({ findings, count: findings.length });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });

    opusBridgeRouter.get('/patrol-rounds', async (req: Request, res: Response) => {
      try {
        const db = getDb();
        const rounds = await queryTable(db, ['scout_patrol_rounds', 'builder_patrol_rounds', 'patrol_rounds'], 'ORDER BY created_at DESC', Math.min(Number(req.query.limit) || 20, 50));
        res.json({ rounds, count: rounds.length });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });

    opusBridgeRouter.get('/patrol-deep-models', async (_req: Request, res: Response) => {
      try {
        const db = getDb();
        const models = await queryTable(db, ['scout_deep_models', 'builder_deep_models', 'deep_patrol_models'], '', 50);
        res.json({ models, count: models.length });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });

    opusBridgeRouter.get('/read-file', async (req: Request, res: Response) => {
      try {
        const filePath = String(req.query.path || '');
        if (!filePath) { res.status(400).json({ error: 'path required' }); return; }
        const token = process.env.GITHUB_TOKEN || process.env.GH_PAT || '';
        const resp = await fetch(`https://api.github.com/repos/G-Dislioglu/soulmatch/contents/${filePath}?ref=main`, { headers: { Authorization: `Bearer ${token}`, Accept: 'application/vnd.github.v3.raw' } });
        if (!resp.ok) { res.status(resp.status).json({ error: resp.statusText }); return; }
        res.json({ path: filePath, size: (await resp.text()).length, content: await resp.clone().text() });
      } catch (err) { res.status(500).json({ error: String(err) }); }
    });

    console.log('[patrol-mount] 5 patrol endpoints registered on opusBridgeRouter');
  } catch (err) {
    console.error('[patrol-mount] Failed to register:', err);
  }
}, 100);
