{
  "name": "soulmatch-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "astro:probe": "node scripts/astro-probe-check.mjs",
    "astro:contract:probe": "node scripts/astro-contract-probe-check.mjs",
    "geo:probe": "node scripts/geo-probe-check.mjs",
    "scoring:probe": "node scripts/scoring-probe-check.mjs",
    "match:probe": "node scripts/match-probe-check.mjs",
    "match:narrative:probe": "node scripts/match-narrative-probe-check.mjs",
    "narrative:probe": "node scripts/narrative-probe-check.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sweph", "esbuild"]
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "sweph": "2.10.3-b-1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
